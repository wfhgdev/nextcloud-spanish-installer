#!/bin/bash

# ==============================================================================
# Script de Instalación Interactiva de Nextcloud 33 (Calificación A+)
# Entorno: Ubuntu Server 26.04 LTS | MariaDB 11.8 | Apache 2.4 | PHP 8.5
# Autor: wfhgdev
# Fecha: 2026
# ==============================================================================

# Colores para la trazabilidad en consola
export NC='\033[0m'
export VERDE='\033[0;32m'
export CYAN='\033[0;36m'
export AMARILLO='\033[1;33m'
export ROJO='\033[0;31m'

# --- FASE 1: VERIFICACIONES DE CONTROL DE CALIDAD ---
echo -e "${CYAN}[1/10] Ejecutando pruebas de control de calidad del entorno...${NC}"

# Verificar privilegios de root
if [ "$EUID" -ne 0 ]; then
    echo -e "${ROJO}[ERROR] Este script debe ejecutarse con privilegios de root (sudo).${NC}"
    exit 1
fi

# Verificar versión de Ubuntu Server (Debe ser 26.04)
if [ -f /etc/os-release ]; then
    . /etc/os-release
    if [ "$VERSION_ID" != "26.04" ]; then
        echo -e "${ROJO}[ERROR] Este script está diseñado exclusivamente para Ubuntu 26.04 LTS.${NC}"
        exit 1
    fi
else
    echo -e "${ROJO}[ERROR] No se pudo determinar la distribución del sistema operativo.${NC}"
    exit 1
fi

# Verificar recursos mínimos (2GB RAM mínimos para producción)
TOTAL_RAM=$(free -m | awk '/^Mem:/{print $2}')
if [ "$TOTAL_RAM" -lt 2000 ]; then
    echo -e "${AMARILLO}[ADVERTENCIA] Se detectaron menos de 2GB de RAM ($TOTAL_RAM MB). Nextcloud podría tener problemas de rendimiento.${NC}"
    read -p "¿Desea continuar de todos modos? (s/n): " CONTINUAR
    [[ "$CONTINUAR" != "s" ]] && exit 1
fi

echo -e "${VERDE}[OK] Entorno validado con éxito.${NC}\n"

# --- FASE 2: ASISTENTE INTERACTIVO DE RECOPILACIÓN DE DATOS ---
echo -e "${CYAN}[2/10] Iniciando asistente interactivo de configuración...${NC}"

# Solicitar dominio o IP pública
while :; do
    read -p "Ingrese el nombre de dominio o dirección IP pública de su servidor: " DOMAIN
    if [ -z "$DOMAIN" ]; then
        echo -e "${ROJO}El dominio no puede estar vacío.${NC}"
    else
        break
    fi
done

# Datos del Administrador de Nextcloud
while :; do
    read -p "Defina el nombre del usuario administrador de Nextcloud [admin]: " NC_ADMIN
    NC_ADMIN=${NC_ADMIN:-admin}
    [[ "$NC_ADMIN" == *" "* ]] && echo -e "${ROJO}El usuario no puede contener espacios.${NC}" || break
done

while :; do
    read -s -p "Defina la contraseña del administrador de Nextcloud (mínimo 8 caracteres): " NC_PASS
    echo ""
    if [ ${#NC_PASS} -lt 8 ]; then
        echo -e "${ROJO}Contraseña demasiado corta.${NC}"
    else
        break
    fi
done

# Datos de la Base de Datos
read -p "Nombre de la base de datos MariaDB [nextcloud_db]: " DB_NAME
DB_NAME=${DB_NAME:-nextcloud_db}
read -p "Usuario de la base de datos MariaDB [nextcloud_user]: " DB_USER
DB_USER=${DB_USER:-nextcloud_user}

while :; do
    read -s -p "Contraseña para el usuario de la base de datos: " DB_PASS
    echo ""
    if [ -z "$DB_PASS" ]; then
        echo -e "${ROJO}La contraseña de la base de datos es obligatoria.${NC}"
    else
        break
    fi
done

echo -e "${VERDE}[OK] Datos recopilados de forma segura.${NC}\n"

# --- FASE 3: ACTUALIZACIÓN E INSTALACIÓN DEL STACK (LAMP + REDIS) ---
echo -e "${CYAN}[3/10] Actualizando repositorios e instalando paquetes del sistema...${NC}"
apt-get update -y && apt-get upgrade -y

echo -e "${CYAN}Instalando Apache 2.4, MariaDB 11.8, PHP 8.5 y Redis...${NC}"
# Nota: En Ubuntu 26.04 LTS, PHP 8.5 y MariaDB 11.x se gestionan mediante paquetería nativa o PPA oficial.
apt-get install -y apache2 mariadb-server mariadb-client redis-server curl unzip bzip2 sudo \
php8.5 php8.5-fpm php8.5-mysql php8.5-intl php8.5-curl php8.5-gd php8.5-xml php8.5-zip \
php8.5-mbstring php8.5-bcmath php8.5-gmp php8.5-imagick php8.5-opcache php8.5-redis php8.5-bz2

echo -e "${VERDE}[OK] Stack de software base instalado correctamente.${NC}\n"

# --- FASE 4: CONFIGURACIÓN SEGURA DE MARIADB 11.8 ---
echo -e "${CYAN}[4/10] Configurando el motor de base de datos MariaDB 11.8...${NC}"
systemctl start mariadb
systemctl enable mariadb

# Creación de la base de datos y usuario con los máximos estándares de compatibilidad
mariadb -u root <<EOF
CREATE DATABASE IF NOT EXISTS \`${DB_NAME}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;
CREATE USER IF NOT EXISTS '${DB_USER}'@'localhost' IDENTIFIED BY '${DB_PASS}';
GRANT ALL PRIVILEGES ON \`${DB_NAME}\`.* TO '${DB_USER}'@'localhost';
FLUSH PRIVILEGES;
EOF

if [ $? -eq 0 ]; then
    echo -e "${VERDE}[OK] Base de datos y privilegios creados con éxito.${NC}\n"
else
    echo -e "${ROJO}[ERROR] Error al inicializar las tablas de MariaDB.${NC}"
    exit 1
fi

# --- FASE 5: OPTIMIZACIÓN DE PHP 8.5 PARA CALIFICACIÓN A+ ---
echo -e "${CYAN}[5/10] Aplicando optimizaciones de rendimiento y seguridad en PHP 8.5...${NC}"
PHP_INI="/etc/php/8.5/fpm/php.ini"

if [ -f "$PHP_INI" ]; then
    # Ajustes requeridos por la auditoría interna de seguridad de Nextcloud
    sed -i "s|memory_limit =.*|memory_limit = 512M|g" "$PHP_INI"
    sed -i "s|upload_max_filesize =.*|upload_max_filesize = 10G|g" "$PHP_INI"
    sed -i "s|post_max_size =.*|post_max_size = 10G|g" "$PHP_INI"
    sed -i "s|max_execution_time =.*|max_execution_time = 3600|g" "$PHP_INI"
    sed -i "s|;date.timezone =.*|date.timezone = Europe/Madrid|g" "$PHP_INI"
    
    # Configuración estricta de OPcache para producción
    sed -i "s|;opcache.enable=.*|opcache.enable=1|g" "$PHP_INI"
    sed -i "s|;opcache.enable_cli=.*|opcache.enable_cli=1|g" "$PHP_INI"
    sed -i "s|;opcache.interned_strings_buffer=.*|opcache.interned_strings_buffer=16|g" "$PHP_INI"
    sed -i "s|;opcache.max_accelerated_files=.*|opcache.max_accelerated_files=10000|g" "$PHP_INI"
    sed -i "s|;opcache.memory_consumption=.*|opcache.memory_consumption=128|g" "$PHP_INI"
    sed -i "s|;opcache.save_comments=.*|opcache.save_comments=1|g" "$PHP_INI"
    sed -i "s|;opcache.revalidate_freq=.*|opcache.revalidate_freq=1|g" "$PHP_INI"
    
    systemctl restart php8.5-fpm
    echo -e "${VERDE}[OK] Directivas OPcache y límites de memoria asignados en php.ini.${NC}\n"
else
    echo -e "${ROJO}[ERROR] No se pudo localizar el archivo php.ini en la ruta esperada.${NC}"
    exit 1
fi

# --- FASE 6: DESPLIEGUE DEL CÓDIGO FUENTE DE NEXTCLOUD 33 ---
echo -e "${CYAN}[6/10] Descargando y desplegando Nextcloud 33 Production...${NC}"
NC_PATH="/var/www/nextcloud"

rm -rf "$NC_PATH"
curl -sL https://download.nextcloud.com/server/releases/latest-33.tar.bz2 -o /tmp/nextcloud.tar.bz2
tar -xjf /tmp/nextcloud.tar.bz2 -C /var/www/
mkdir -p "$NC_PATH/data"

# Ajustar permisos iniciales para el servidor web apache (www-data)
chown -R www-data:www-data "$NC_PATH"
chmod -R 755 "$NC_PATH"
echo -e "${VERDE}[OK] Archivos binarios desplegados en $NC_PATH.${NC}\n"

# --- FASE 7: INSTALACIÓN DESATENDIDA MEDIANTE INTERFAZ OCC ---
echo -e "${CYAN}[7/10] Ejecutando el proceso de instalación core con OCC...${NC}"
cd "$NC_PATH"

sudo -u www-data php occ maintenance:install \
  --database="mysql" \
  --database-name="$DB_NAME" \
  --database-user="$DB_USER" \
  --database-pass="$DB_PASS" \
  --admin-user="$NC_ADMIN" \
  --admin-pass="$NC_PASS" \
  --data-dir="$NC_PATH/data"

if [ $? -eq 0 ]; then
    echo -e "${VERDE}[OK] Instalación de la estructura interna completada con éxito.${NC}\n"
else
    echo -e "${ROJO}[ERROR] Error fatal durante la instalación mediante la CLI OCC de Nextcloud.${NC}"
    exit 1
fi

# --- FASE 8: INTEGRACIÓN DE CACHÉ DE MEMORIA RAM CON REDIS ---
echo -e "${CYAN}[8/10] Vinculando Redis Server para la gestión de bloqueos de archivos y caché...${NC}"
systemctl start redis-server
systemctl enable redis-server

# Inyectar configuraciones de Redis en la matriz de config.php de Nextcloud
sudo -u www-data php occ config:system:set memcache.local --value="\OC\Memcache\Redis"
sudo -u www-data php occ config:system:set memcache.distributed --value="\OC\Memcache\Redis"
sudo -u www-data php occ config:system:set memcache.locking --value="\OC\Memcache\Redis"
sudo -u www-data php occ config:system:set redis --value='{"host":"127.0.0.1","port":6379,"timeout":0.0}' --type=json
sudo -u www-data php occ config:system:set overwrite.cli.url --value="https://$DOMAIN"
sudo -u www-data php occ config:system:set trusted_domains 1 --value="$DOMAIN"

echo -e "${VERDE}[OK] Redis configurado como backend de caché de memoria RAM.${NC}\n"

# --- FASE 9: CONFIGURACIÓN DE VIRTUALHOSTS CON CABECERAS DE SEGURIDAD A+ ---
echo -e "${CYAN}[9/10] Creando configuraciones en Apache con directivas HSTS estrictas...${NC}"
VHOST_CONF="/etc/apache2/sites-available/nextcloud.conf"

# Habilitar módulos necesarios en Apache para seguridad y enrutamiento
a2enmod rewrite headers env dir mime ssl proxy proxy_fcgi setenvif mpm_event > /dev/null
a2enconf php8.5-fpm > /dev/null

cat <<EOF > "$VHOST_CONF"
<VirtualHost *:80>
    ServerName $DOMAIN
    DocumentRoot $NC_PATH

    # Redirección permanente a HTTPS para garantizar cifrado de extremo a extremo
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</VirtualHost>

<VirtualHost *:443>
    ServerName $DOMAIN
    DocumentRoot $NC_PATH

    # --- CERTIFICADOS SSL ---
    # Nota: Utiliza certificados Snakeoil provisionales. Reemplazar por Let's Encrypt para producción.
    SSLEngine on
    SSLCertificateFile /etc/ssl/certs/ssl-cert-snakeoil.pem
    SSLCertificateKeyFile /etc/ssl/private/ssl-cert-snakeoil.key

    # --- CABECERAS ESTRICTAS PARA CALIFICACIÓN SEGURIDAD A+ ---
    Header always set Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Robots "noindex, nofollow"
    Header always set Referrer-Policy "no-referrer"

    # Redirecciones de descubrimiento de servicios requeridas (.well-known)
    Redirect 301 /.well-known/carddav /remote.php/dav
    Redirect 301 /.well-known/caldav /remote.php/dav
    Redirect 301 /.well-known/webfinger /index.php/.well-known/webfinger
    Redirect 301 /.well-known/nodeinfo /index.php/.well-known/nodeinfo

    <Directory $NC_PATH/>
        Options +FollowSymlinks
        AllowOverride All

        <IfModule mod_dav.c>
            Dav off
        </IfModule>

        SetEnv HOME $NC_PATH
        SetEnv HTTP_HOME $NC_PATH
    </Directory>
</VirtualHost>
EOF

# Activar el sitio y reiniciar Apache
a2ensite nextcloud.conf > /dev/null
a2dissite 000-default.conf > /dev/null
systemctl restart apache2

echo -e "${VERDE}[OK] Archivos de configuración de Apache generados y aplicados.${NC}\n"

# --- FASE 10: TAREAS DE CONSOLIDACIÓN Y CRON DEL SISTEMA ---
echo -e "${CYAN}[10/10] Aplicando el modelo de permisos final y configurando Cron del sistema...${NC}"

# Establecer el modo background de Nextcloud a AJAX o Cron (Se recomienda Cron para producción)
sudo -u www-data php occ backgroundjob:setsystemcron

# Programación de la ejecución de las tareas en segundo plano de Nextcloud cada 5 minutos
crontab -u www-data -l 2>/dev/null | { cat; echo "*/5 * * * * php -f $NC_PATH/cron.php > /dev/null 2>&1"; } | crontab -u www-data -

# Indexación inicial de la base de datos para corregir índices ausentes
sudo -u www-data php occ db:add-missing-indices --no-interaction
sudo -u www-data php occ db:add-missing-columns --no-interaction

echo -e "${VERDE}======================================================================${NC}"
echo -e "${VERDE}             ¡INSTALACIÓN DE NEXTCLOUD COMPLETADA CON ÉXITO!          ${NC}"
echo -e "${VERDE}======================================================================${NC}"
echo -e "${CYAN}Dominio de acceso:${NC} https://$DOMAIN"
echo -e "${CYAN}Usuario Administrador:${NC} $NC_ADMIN"
echo -e "${AMARILLO}Nota de seguridad:${NC} Para consolidar la calificación A+ en entornos públicos,"
echo -e "recuerde sustituir los certificados SSL provisionales por unos válidos de Let's Encrypt."
echo -e "${VERDE}======================================================================${NC}"
